---
import Layout from "../layouts/Layout.astro";

const path = Astro.url.pathname;
const isES = path.startsWith('/es');

const base = isES ? '/es' : '/en';

const t = {
  title: isES ? "Datos y Automatización" : "Data & Automations",

  sectionTitle: isES ? "Sistemas de Datos" : "Big Data Systems",

  text: isES
    ? "Creamos infraestructuras de datos seguras y accesibles que te permiten aprovechar la información que genera tu negocio a través de transacciones e interacciones online. Al organizar y centralizar los datos, puedes detectar tendencias rápidamente, identificar ineficiencias y tomar decisiones más informadas. Con el sistema adecuado, los datos del día a día se convierten en oportunidades reales de crecimiento."
    : "We build secure, accessible data infrastructures that help you harness the information your business generates through transactions and online interactions. By organizing and centralizing your data, you can quickly spot trends, identify inefficiencies, and make better decisions. With the right system in place, everyday data becomes real growth opportunities.",

  ctaTitle: isES
    ? "Ahorra tiempo con soluciones de software"
    : "Save Time With Software Solutions",

  ctaText: isES
    ? "Utiliza tecnología moderna para simplificar tus operaciones diarias y reducir tareas repetitivas. Estas herramientas también mejoran la experiencia del cliente, ayudando a tu negocio a mantenerse competitivo en un mercado en constante cambio. Además, son accesibles y fáciles de implementar."
    : "Use modern technology to simplify your daily operations and reduce repetitive tasks. These tools also improve customer experience, helping your business stay competitive in a fast-moving market. Best of all, they are affordable and easy to implement.",

  ctaButton: isES
    ? "AGENDA UNA CONSULTA"
    : "SCHEDULE A CONSULTATION"
};
---

<Layout title={t.title}>

<!-- TITLE STRIP WITH IMAGE -->
<section class="relative h-[180px] md:h-[180px] text-white flex items-end">

  <div 
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style="background-image: url('/images/service-1-2.png');"
  ></div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-8 pb-6 md:pb-8">
    <h1 class="text-[30px] md:text-[44px] font-heading max-w-[700px] leading-[1.2]">
      {t.title}
    </h1>
  </div>

</section>

<!-- CONTENT -->
<section class="bg-white py-4">

  <div class="max-w-5xl mx-auto px-6 text-center">

    <p class="text-[16px] md:text-[18px] text-gray-800 leading-[1.7] font-ui mb-4">
      {t.text}
    </p>

  </div>

</section>

<!-- IMAGE + MASK -->
<section class="bg-white pb-8">

  <div class="w-full flex flex-col items-center">

    <div class="w-full md:max-w-[900px] px-2 md:px-0">

      <div class="relative w-full overflow-hidden rounded-lg border-2"
           style="border-color: var(--color-primary)">

        <img 
          src="/images/service-data.gif"
          class="w-full h-[250px] md:h-[550px] object-cover object-center"
        />

        <div class="absolute top-0 left-1/2 -translate-x-1/2 
                    w-[30%] h-[20%] 
                    bg-white rounded-b-md">
        </div>

      </div>

    </div>

  </div>

</section>

<!-- SOFTWARE CTA BLOCK -->
<section class="bg-white py-10">

  <div class="max-w-5xl mx-auto px-6">

    <div class="grid md:grid-cols-[0.8fr_1.2fr] items-stretch">

      <!-- LEFT -->
      <div class="flex justify-center md:justify-start">

        <div class="w-full h-[140px] md:h-auto overflow-hidden">
          <img 
            src="/images/service-data-2.jpg"
            class="w-full h-full object-cover"
          />
        </div>

      </div>

      <!-- RIGHT -->
      <div class="bg-gray-100 p-6 md:p-6">

        <h2 class="text-[24px] md:text-[36px] font-heading mb-4 text-left">
          {t.ctaTitle}
        </h2>

        <p class="text-[15px] md:text-[18px] text-gray-800 leading-[1.7] font-ui text-left">
          {t.ctaText}
        </p>

      </div>

    </div>

    <!-- BUTTON -->
    <div class="mt-10 mb-2 flex justify-center">
      <a href={`${base}/contact`} class="btn-primary">
        {t.ctaButton}
      </a>
    </div>

  </div>

</section>

</Layout>