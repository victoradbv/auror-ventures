---
import Layout from "../layouts/Layout.astro";

const path = Astro.url.pathname;
const isES = path.startsWith('/es');

const base = isES ? '/es' : '/en';

const t = {
  title: isES ? "Sobre Nosotros" : "About Us",

  intro: isES
    ? "Nuestro equipo cuenta con una trayectoria comprobada en empresas de distintos tamaños y sectores. Con experiencia internacional y trabajando con equipos globales, aportamos una visión práctica orientada a mejorar resultados. Nuestro objetivo es ayudar a los negocios a crecer con soluciones claras, eficientes y basadas en datos."
    : "Our team has a proven track record of success within business of a variety of industries. With experience living in different countries and working with global teams, we bring valuable insights that drive business success. Our goal is to provide practical advice and support, helping businesses thrive at every stage of growth.",

  btn: isES ? "AGENDA UNA CONSULTA" : "SCHEDULE A CONSULTATION",
};

const team = [
  {
    name: "Victor",
    text: isES
      ? "Conecta finanzas y tecnología para crear sistemas que ayudan a los negocios a operar de forma más eficiente."
      : "Brings together finance and technology to create systems with modern infrastructure.",
    img: "/images/team-1.jpg",
    linkedin: "https://www.linkedin.com/in/victordosbarros/"
  },
  {
    name: "Sebas",
    text: isES
      ? "Con experiencia desde el diseño de videojuegos hasta plataformas exigentes, desarrolla software que se mantiene sólido y estable."
      : "With experience from game design to demanding platforms, he builds software that stays reliable.",
    img: "/images/team-2.jpg",
    linkedin: "https://www.linkedin.com/in/sdosbarros/"
  },
  {
    name: "Ira",
    text: isES
      ? "Crea experiencias digitales inmersivas, dando vida a ideas a través de un diseño virtual cuidado y detallado."
      : "Creates immersive digital experiences, bringing ideas to life through refined virtual design.",
    img: "/images/team-3.jpg",
    linkedin: "https://www.linkedin.com/in/iryna-gural-27a289210/"
  },
  {
    name: "Lens",
    text: isES
      ? "Transforma datos en información clara, mejorando procesos de reporte y apoyando decisiones más inteligentes."
      : "Transforms data into clear insights, improving financial reporting and decision-making.",
    img: "/images/team-4.jpg",
    linkedin: "https://www.linkedin.com/in/lens-maldonado-1ba5141a3/"
  }
];
---

<Layout tabTitle={isES ? "Nosotros" : "About Us"}>

<!-- TITLE STRIP -->
<section class="bg-[var(--color-primary)] py-6 text-white text-center">
  <h1 class="text-[30px] md:text-[44px] font-heading">
    {t.title}
  </h1>
</section>

<!-- PARAGRAPH -->
<section class="bg-white py-10">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <p class="font-body text-[16px] md:text-[18px] font-medium leading-[1.85] tracking-[0.6px] text-gray-800">
      {t.intro}
    </p>
  </div>
</section>

<!-- TEAM -->
<section class="bg-white pb-12">
  <div class="max-w-6xl mx-auto px-6">

    <div class="grid md:grid-cols-2 gap-8">

      {team.map(member => (

        <div class="bg-[var(--color-primary)] text-white rounded-lg p-6 flex gap-4">

          <!-- IMAGE -->
          <img
            src={member.img}
            class="w-20 h-20 md:w-24 md:h-24 rounded-full object-cover shrink-0"
          />

          <!-- CONTENT -->
          <div class="flex-1">

            <!-- NAME + LINKEDIN -->
            <div class="flex items-center gap-2">

              <h3 class="font-heading text-lg md:text-xl">
                {member.name}
              </h3>

              <a href={member.linkedin}
                target="_blank"
                class="
                  w-5 h-5
                  bg-white
                  rounded-[3px]
                  flex items-center justify-center
                  transition-transform duration-200
                  hover:scale-110
                ">

                <span class="
                  text-[10px] md:text-[12px]
                  font-bold
                  leading-none
                  text-[var(--color-primary)]
                ">
                  in
                </span>

              </a>

            </div>

            <!-- TEXT -->
            <p class="text-sm md:text-base text-white/90 mt-2">
              {member.text}
            </p>

          </div>

        </div>

      ))}

    </div>

    <!-- BUTTON -->
    <div class="mt-12 flex justify-center">

      <a href=`${base}/contact`
        class="btn-primary flex items-center justify-center text-center"
        style="width:288px;"
      >
        {t.btn}
      </a>

    </div>

  </div>
</section>

</Layout>