---
import Layout from "../layouts/Layout.astro";

const path = Astro.url.pathname;
const isES = path.startsWith('/es');

const base = isES ? '/es' : '/en';

const t = {
  title: isES ? "Software y Cloud" : "Software & Cloud",

  services: [
    {
      title: isES ? "Desarrollo de Software y Aplicaciones" : "Software & Application Development",
      text: isES
        ? "¿Tienes una idea o concepto para un software, una web o una app? Lo convertimos en una solución completamente funcional, diseñada para rendir, soportar la demanda y ofrecer una experiencia de usuario de alta calidad."
        : "Have an idea or concept for software, a website, or an app? We turn it into a fully functional solution, designed to perform, handle demand, and deliver a high-quality user experience.",
      img: "/images/service-2-2.png",
      link: `${base}/software-development`
    },
    {
      title: isES ? "Infraestructura Cloud" : "Cloud Infrastructure",
      text: isES
        ? "Modernizamos y actualizamos los sistemas empresariales a través de infraestructura cloud, gestión de datos y entornos seguros. Esto crea la base necesaria para integrar IA y aprovechar mejor tus datos."
        : "We modernize and upgrade business systems through cloud infrastructure, data management, and secure environments. This creates the foundation needed to integrate AI and make better use of your data.",
      img: "/images/service-2-1.png",
      link: `${base}/cloud-infrastructure`
    }
  ]
};
---

<Layout tabTitle={isES ? "Servicios" : "Services"}>

<!-- TITLE STRIP -->
<section class="bg-[var(--color-primary)] py-6 text-white text-center">
  <h1 class="text-[30px] md:text-[44px] font-heading">
    {t.title}
  </h1>
</section>

<!-- SERVICES -->
<section class="bg-white py-16">

  <div class="max-w-5xl mx-auto px-6">

    <div class="grid md:grid-cols-2 gap-10">

      {t.services.map(service => (

        <div class="rounded-lg overflow-hidden flex flex-col h-full">

          <!-- IMAGE BLOCK -->
          <a href={service.link} class="block relative group">

            <div
              class="h-[140px] md:h-[160px] bg-cover bg-center"
              style={`background-image: url(${service.img})`}
            ></div>

            <div class="absolute inset-0 bg-black/30 group-hover:bg-black/50 transition"></div>

            <div class="absolute bottom-4 left-4 right-4 flex justify-between items-center text-white">

              <h3 class="text-xl md:text-2xl font-heading max-w-[85%] leading-tight transition-transform group-hover:translate-x-1">
                {service.title}
              </h3>

              <span class="text-2xl md:text-3xl transition-transform group-hover:translate-x-1">
                ➙
              </span>

            </div>

          </a>

          <!-- TEXT BLOCK (fixed height for consistency) -->
          <div class="bg-gray-100 px-5 py-5 h-[180px] md:h-[140px] flex items-start">

            <p class="text-base md:text-base text-gray-700 leading-[1.6] font-ui">
              {service.text}
            </p>

          </div>

        </div>

      ))}

    </div>

  </div>

</section>

</Layout>