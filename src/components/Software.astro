---
import Layout from "../layouts/Layout.astro";

const path = Astro.url.pathname;
const isES = path.startsWith('/es');

const base = isES ? '/es' : '/en';

const description = isES
  ? "Convertimos tu idea en una aplicación, sitio web o solución de software completamente funcional y lista para escalar."
  : "We turn your idea into a fully functional app, website, or software solution built to scale.";

const t = {
  title: isES ? "Desarrollo de Software y Aplicaciones" : "Software & Application Development",

  sectionTitle: isES ? "Sistemas de Datos" : "Big Data Systems",

  text: isES
    ? "Desarrollamos software a medida utilizando arquitecturas modernas que garantizan rendimiento, escalabilidad y mantenibilidad desde el inicio. Esto incluye sistemas backend, APIs, bases de datos e interfaces de usuario, asegurándonos de que todos los componentes funcionen de forma fiable y puedan manejar una mayor complejidad y demanda."
    : "We develop custom software using modern architectures that support performance, scalability, and maintainability from the start. This includes backend systems, APIs, databases, and user interfaces, ensuring all components work together reliably and can handle increasing complexity and demand.",

  ctaTitle: isES
    ? "¿Por qué elegirnos?"
    : "Why Choose Us?",

  ctaText: isES
    ? "Utilizamos una estructura clara y ejecución disciplinada para garantizar que cada solución cumpla sus requisitos desde el inicio. Nuestro equipo tiene experiencia en finanzas, banca, comercio electrónico, logística y educación, trabajando con empresas a escala global para entregar soluciones que se adaptan a entornos de negocio reales."
    : "With a strong track record of delivered projects, development is approached with clear structure and disciplined execution. Our team brings experience across finance, banking, e-commerce, logistics, and education, working with companies at a global scale to deliver solutions that fit real business environments.",
  
  ctaButton: isES
    ? "AGENDA UNA CONSULTA"
    : "SCHEDULE A CONSULTATION"
};
---

<Layout tabTitle={isES ? "Servicios" : "Services"} description={description}>

<!-- TITLE STRIP WITH IMAGE -->
<section class="relative h-[180px] md:h-[180px] text-white flex items-end">

  <div 
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style="background-image: url('/images/service-2-2.png');"
  ></div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-8 pb-6 md:pb-8">
    <h1 class="text-[30px] md:text-[44px] font-heading max-w-[800px] leading-[1.2]">
      {t.title}
    </h1>
  </div>

</section>

<!-- CONTENT -->
<section class="bg-white py-4">

  <div class="max-w-5xl mx-auto px-6 text-center">

    <p class="text-[16px] md:text-[18px] text-gray-800 leading-[1.7] font-ui mb-4">
      {t.text}
    </p>

  </div>

</section>

<!-- IMAGE-->
<section class="bg-white pb-8">

  <div class="w-full flex flex-col items-center">

    <div class="w-full md:max-w-[950px] px-2 md:px-0">

      <div class="relative w-full overflow-hidden rounded-lg border-2
                  transition-all duration-300
                  hover:shadow-[0_0_20px_rgba(0,0,0,0.25)]"
           style="border-color: var(--color-primary)">

        <img 
          src="/images/service-software-1.png"
          class="w-full object-contain object-center"
        />

      </div>

    </div>

  </div>

</section>

<!-- SOFTWARE CTA BLOCK -->
<section class="bg-white py-10">

  <div class="max-w-5xl mx-auto px-6">

    <div class="grid md:grid-cols-[0.8fr_1.2fr] items-stretch">

      <!-- LEFT -->
      <div class="flex justify-center md:justify-start">

        <div class="w-full h-[140px] md:h-[350px] overflow-hidden">
          <img 
            src="/images/service-software-2.jpg"
            class="w-full h-full object-cover"
          />
        </div>

      </div>

      <!-- RIGHT -->
      <div class="bg-gray-100 p-6 md:p-6">

        <h2 class="text-[24px] md:text-[36px] font-heading mb-4 text-left">
          {t.ctaTitle}
        </h2>

        <p class="text-[15px] md:text-[18px] text-gray-800 leading-[1.7] font-ui text-left">
          {t.ctaText}
        </p>

      </div>

    </div>

    <!-- BUTTON -->
    <div class="mt-10 mb-2 flex justify-center">
      <a href={`${base}/contact`} class="btn-primary">
        {t.ctaButton}
      </a>
    </div>

  </div>

</section>

</Layout>