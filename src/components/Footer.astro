---
const path = Astro.url.pathname;
const isES = path.startsWith('/es');

// Base path
const base = isES ? '/es' : '/en';

// Translations (ONLY TEXT)
const t = isES
  ? {
      services: "Servicios",
      company: "Empresa",
      finance: "Soluciones Financieras",
      software: "Software & Cloud",
      about: "Sobre Nosotros",
      contact: "Contacto",
      legal: "Legal",
    }
  : {
      services: "Services",
      company: "Company",
      finance: "Finance Solutions",
      software: "Software & Cloud",
      about: "About Us",
      contact: "Contact",
      legal: "Legal",
    };
---

<footer 
  class="mt-2 text-white"
  style="background-image: url('/images/Footer-background.jpg'); background-size: cover; background-position: center bottom;"
>

  <!-- Main Content -->
  <div class="container-custom h-auto md:h-[130px] py-6 md:py-1 flex items-center">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start md:items-center w-full">

      <!-- Logo -->
      <div class="flex justify-start">
        <img 
          src="/images/White-logo.png" 
          alt="Auror Ventures" 
          class="h-14 md:h-20 lg:h-24 w-auto object-contain"
        />
      </div>

      <!-- Services + Company wrapper -->
      <div class="grid grid-cols-2 gap-10 md:contents">

        <!-- Services -->
        <div>
          <h3 class="mb-3 font-heading text-base md:text-lg text-white">
            {t.services}
          </h3>

          <ul class="space-y-2 font-ui text-sm md:text-base text-muted-light leading-tight">
            <li>
              <a href={`${base}/services-finance-solutions`} class="hover:text-white whitespace-nowrap">
                {t.finance}
              </a>
            </li>
            <li>
              <a href={`${base}/services-software-cloud`} class="hover:text-white whitespace-nowrap">
                {t.software}
              </a>
            </li>
            <li class="hidden md:block opacity-0 select-none">Placeholder</li>
          </ul>
        </div>

        <!-- Company -->
        <div>
          <h3 class="mb-3 font-heading text-base md:text-lg text-white">
            {t.company}
          </h3>

          <ul class="space-y-2 font-ui text-sm md:text-base text-muted-light leading-tight">
            <li>
              <a href={`${base}/about-us`} class="hover:text-white">
                {t.about}
              </a>
            </li>
            <li>
              <a href={`${base}/contact`} class="hover:text-white">
                {t.contact}
              </a>
            </li>
            <li>
              <a href="#" class="hover:text-white">
                {t.legal}
              </a>
            </li>
          </ul>
        </div>

      </div>

    </div>

  </div>

  <!-- Bottom Bar -->
  <div class="bg-black text-muted-light text-xs">
    <div class="container-custom py-1 text-left">
      <span class="font-sans">©</span> aurorventures.com
    </div>
  </div>

</footer>