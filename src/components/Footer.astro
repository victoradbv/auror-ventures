---
---

<footer 
  class="mt-20 text-white"
  style="background-image: url('/images/Footer-background.jpg'); background-size: cover; background-position: center bottom;"
>

  <!-- Main Content -->
  <div class="container-custom h-auto md:h-[160px] py-6 md:py-0 flex items-center">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start md:items-center w-full">

      <!-- Logo -->
      <div class="flex justify-start">
        <img 
          src="/images/White-logo.png" 
          alt="Auror Ventures" 
          class="h-14 md:h-20 lg:h-24 w-auto object-contain"
        />
      </div>

      <!-- Services + Company wrapper -->
      <div class="grid grid-cols-2 gap-6 md:contents">

        <!-- Services -->
        <div>
          <h3 class="mb-3 font-heading text-base md:text-lg text-white">
            Services
          </h3>

          <ul class="space-y-2 font-ui text-sm md:text-base text-muted-light leading-tight">
            <li>
              <a href="/services-finance-solutions" class="hover:text-white">
                Finance Solutions
              </a>
            </li>
            <li>
              <a href="/services-software-cloud" class="hover:text-white">
                Software <span class="font-sans">&amp;</span> Cloud
              </a>
            </li>
            <li class="hidden md:block opacity-0 select-none">Placeholder</li>
          </ul>
        </div>

        <!-- Company -->
        <div>
          <h3 class="mb-3 font-heading text-base md:text-lg text-white">
            Company
          </h3>

          <ul class="space-y-2 font-ui text-sm md:text-base text-muted-light leading-tight">
            <li>
              <a href="/about-us" class="hover:text-white">
                About Us
              </a>
            </li>
            <li>
              <a href="/contact" class="hover:text-white">
                Contact
              </a>
            </li>
            <li>
              <a href="#" class="hover:text-white">
                Legal
              </a>
            </li>
          </ul>
        </div>

      </div>

    </div>

  </div>

  <!-- Bottom Bar -->
  <div class="bg-black text-white text-xs">
    <div class="container-custom py-2 text-left">
      <span class="font-sans">©</span> aurorventures.com
    </div>
  </div>

</footer>